# HouseBets Configuration Example
# Copy this to .env and fill in your values

# ============================================
# REQUIRED: Discord Bot Token
# ============================================
# Get this from: https://discord.com/developers/applications
# 1. Create a new application
# 2. Go to "Bot" section
# 3. Click "Reset Token" and copy it here
BOT_TOKEN=your_discord_bot_token_here

# ============================================
# Bot Settings
# ============================================

# Initial balance for new users (in Bucks)
INITIAL_BALANCE=1000

# Name of the mock currency
CURRENCY_NAME=Bucks

# Name of the feed channel where resolved markets are posted
# Bot will auto-create this channel if it doesn't exist
FEED_CHANNEL_NAME=housebets-feed

# ============================================
# Advanced Settings (Optional)
# ============================================

# Database file location (default: housebets.db in current directory)
# DATABASE_PATH=housebets.db

# Initial liquidity for AMM (affects price sensitivity)
# Higher = less price movement per bet
# INITIAL_LIQUIDITY=100
